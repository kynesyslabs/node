{
    "name": "demos-node-software",
    "version": "0.9.5",
    "description": "Demos Node Software",
    "author": "Kynesys Labs",
    "license": "none",
    "private": true,
    "main": "src/index.ts",
    "scripts": {
        "lint": "prettier --plugin-search-dir . --check . && eslint .",
        "lint:fix": "eslint . --fix --ext .ts",
        "prettier-format": "prettier --config .prettierrc.json modules/**/*.ts --write",
        "format": "prettier --plugin-search-dir . --write .",
        "start": "tsx -r tsconfig-paths/register src/index.ts",
        "start:up": "bun install && tsx -r tsconfig-paths/register src/index.ts",
        "start:bun": "bun --tsconfig-override tsconfig.base.json -r tsconfig-paths/register src/index.ts",
        "start:clean": "rm -rf data/chain.db && tsx -r tsconfig-paths/register src/index.ts",
        "start:purge": "rm -rf .demos_identity && rm -rf data/chain.db && tsx -r tsconfig-paths/register src/index.ts",
        "dev": "ts-node-dev --import tsx --respawn --transpile-only src/index.ts",
        "upgrade_sdk": "bun update @kynesyslabs/demosdk --latest",
        "upgrade_deps": "bun update-interactive --latest",
        "upgrade_deps:force": "ncu -u && yarn",
        "keygen": "tsx -r tsconfig-paths/register src/libs/utils/keyMaker.ts",
        "test:chains": "jest --testMatch '**/tests/**/*.ts' --testPathIgnorePatterns src/* tests/utils/* tests/**/_template*  --verbose",
        "restore": "bun run src/utilities/backupAndRestore.ts",
        "typeorm": "typeorm-ts-node-esm",
        "migration:run": "NODE_OPTIONS='--loader ts-node/esm' typeorm-ts-node-esm migration:run -d ./src/model/datasource.ts",
        "migration:revert": "NODE_OPTIONS='--loader ts-node/esm' typeorm-ts-node-esm migration:revert -d ./src/model/datasource.ts",
        "migration:generate": "NODE_OPTIONS='--loader ts-node/esm' typeorm-ts-node-esm migration:generate -d ./src/model/datasource.ts"
    },
    "devDependencies": {
        "@eslint/js": "^9.34.0",
        "@types/bun": "^1.2.10",
        "@types/jest": "^29.5.12",
        "@types/node": "^24.0.10",
        "@types/node-fetch": "^2.6.5",
        "@types/ntp-client": "^0.5.0",
        "@types/terminal-kit": "^2.5.6",
        "@typescript-eslint/eslint-plugin": "^5.62.0",
        "@typescript-eslint/parser": "^5.62.0",
        "eslint": "^9.34.0",
        "jest": "^29.7.0",
        "prettier": "^2.8.0",
        "ts-jest": "^29.3.2",
        "ts-node": "^10.9.1",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.8.3"
    },
    "dependencies": {
        "@cosmjs/encoding": "^0.33.1",
        "@fastify/cors": "^9.0.1",
        "@fastify/swagger": "^8.15.0",
        "@fastify/swagger-ui": "^4.1.0",
        "@kynesyslabs/demosdk": "^2.4.13",
        "@modelcontextprotocol/sdk": "^1.13.3",
        "@octokit/core": "^6.1.5",
        "@types/express": "^4.17.21",
        "@types/http-proxy": "^1.17.14",
        "@types/lodash": "^4.17.4",
        "@types/node-forge": "^1.3.6",
        "alea": "^1.0.1",
        "axios": "^1.6.5",
        "bun": "^1.2.10",
        "cli-progress": "^3.12.0",
        "dotenv": "^16.4.5",
        "ethers": "^6.11.1",
        "express": "^4.19.2",
        "fastify": "^4.28.1",
        "http-proxy": "^1.18.1",
        "lodash": "^4.17.21",
        "node-disk-info": "^1.3.0",
        "node-fetch": "2",
        "node-forge": "^1.3.1",
        "node-seal": "^5.1.3",
        "npm-check-updates": "^16.14.18",
        "ntp-client": "^0.5.3",
        "object-sizeof": "^2.6.3",
        "openpgp": "^5.11.0",
        "pg": "^8.12.0",
        "reflect-metadata": "^0.1.13",
        "rijndael-js": "^2.0.0",
        "rollup-plugin-polyfill-node": "^0.12.0",
        "rubic-sdk": "^5.57.4",
        "seedrandom": "^3.0.5",
        "socket.io": "^4.7.1",
        "socket.io-client": "^4.7.2",
        "sqlite3": "^5.1.6",
        "superdilithium": "^2.0.6",
        "terminal-kit": "^3.1.1",
        "tsconfig-paths": "^4.2.0",
        "tsx": "^3.12.8",
        "typecheck": "^0.1.2",
        "typeorm": "^0.3.17",
        "web3": "^4.16.0",
        "zod": "^3.25.67"
    },
    "type": "module",
    "optionalDependencies": {
        "bufferutil": "^4.0.8",
        "utf-8-validate": "^5.0.10"
    }
}
