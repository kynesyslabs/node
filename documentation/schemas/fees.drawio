        <mxCell id="BOTzpaHG5GplE9pYi8ou-70" value="&lt;h1&gt;DEMOS Contracts&lt;/h1&gt;&lt;div&gt;Manage the payment and collection of fees in native or token currencies (e.g. stablecoins) and attest them on the DEMOS network&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="BOTzpaHG5GplE9pYi8ou-31">
