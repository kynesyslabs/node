        <mxCell id="BOTzpaHG5GplE9pYi8ou-69" value="&lt;h1&gt;DEMOS Native Token&lt;/h1&gt;&lt;div&gt;As web2 and similar contexts are usually not designed to collect fees, DEMOS network takes care of it&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="BOTzpaHG5GplE9pYi8ou-63">
