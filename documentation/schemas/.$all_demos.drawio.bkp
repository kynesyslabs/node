        <mxCell id="rFKnUhQcz_V2Pc9SrVM1-51" value="Complete Request&lt;br&gt;are sent to the &lt;br&gt;consensus process" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fillColor=#d80073;strokeColor=#A50040;curved=1;dashed=1;strokeWidth=2;" parent="1" source="rFKnUhQcz_V2Pc9SrVM1-40" target="rFKnUhQcz_V2Pc9SrVM1-33" edge="1">
