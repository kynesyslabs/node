        <mxCell id="rFKnUhQcz_V2Pc9SrVM1-75" value="Multichain Requests&lt;br&gt;are sent to the&lt;br&gt;consensus process" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;fillColor=#1ba1e2;strokeColor=#006EAF;dashed=1;curved=1;strokeWidth=2;" parent="1" source="rFKnUhQcz_V2Pc9SrVM1-52" target="rFKnUhQcz_V2Pc9SrVM1-33" edge="1">
