# Devnet Configuration
COMPOSE_PROJECT_NAME=demos-devnet

# Postgres
POSTGRES_USER=demosuser
POSTGRES_PASSWORD=demospass
# Host port for the Postgres container. Override (e.g. 5532) if your
# laptop already runs a local Postgres on 5432.
POSTGRES_HOST_PORT=5432

# Node ports (RPC HTTP)
NODE1_PORT=53551
NODE2_PORT=53553
NODE3_PORT=53555
NODE4_PORT=53557
# Rehearsal-only fifth node. Used only when you opt into the `rehearsal`
# docker compose profile (`docker compose --profile rehearsal up`).
NODE5_PORT=53559

# OmniProtocol ports (P2P)
NODE1_OMNI_PORT=53552
NODE2_OMNI_PORT=53554
NODE3_OMNI_PORT=53556
NODE4_OMNI_PORT=53558
NODE5_OMNI_PORT=53560

# Persistence mode (set to 1 for persistent volumes)
PERSISTENT=0
