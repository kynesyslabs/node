        <mxCell id="Qqf6wXoDEP0wQ5kBnup_-46" value="&lt;br&gt;DEMOS&lt;br&gt;Network" style="html=1;whiteSpace=wrap;shape=isoCube2;backgroundOutline=1;isoAngle=15;fillColor=#1ba1e2;fontColor=#ffffff;strokeColor=#006EAF;" vertex="1" parent="1">
