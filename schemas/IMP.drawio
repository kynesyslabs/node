        <mxCell id="Qqf6wXoDEP0wQ5kBnup_-43" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;Fast, off-chain, trustless verification and execution&lt;/font&gt;" style="shape=flexArrow;endArrow=classic;html=1;rounded=0;fillColor=#60a917;strokeColor=#2D7600;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
