{
    "openapi": "3.0.0",
    "info": {
      "title": "RPC Server API - Demos Network",
      "description": "API for RPC Servers on Demos Network",
      "version": "1.0.0"
    },
    "tags": [
      { "name": "RPC", "description": "RPC related endpoints" }
    ],
    "components": {
      "securitySchemes": {
        "signature": {
          "type": "apiKey",
          "name": "signature",
          "in": "header"
        },
        "identity": {
          "type": "apiKey",
          "name": "identity",
          "in": "header"
        }
      },
      "schemas": {
        "AnyType": {
          "type": "object",
          "description": "Any type of data"
        },
        "RPCRequest": {
          "type": "object",
          "required": ["method", "params"],
          "properties": {
            "method": {
              "type": "string",
              "description": "The name of the RPC method to execute"
            },
            "params": {
              "type": "array",
              "description": "An array of parameters for the RPC method",
              "items": {
                "$ref": "#/components/schemas/AnyType"
              }
            }
          }
        },
        "RPCResponse": {
          "type": "object",
          "properties": {
            "result": {
              "type": "number",
              "description": "The result code of the RPC call"
            },
            "response": {
              "$ref": "#/components/schemas/AnyType",
              "description": "The actual response from the RPC call"
            },
            "require_reply": {
              "type": "boolean",
              "description": "Indicates if a reply is required"
            },
            "extra": {
              "$ref": "#/components/schemas/AnyType",
              "description": "Additional data returned by the RPC call"
            }
          }
        }
      }
    },
    "paths": {
      "/": {
        "post": {
          "summary": "Execute RPC method",
          "description": "Executes the specified RPC method with given parameters",
          "tags": ["RPC"],
          "security": [
            {
              "signature": [],
              "identity": []
            }
          ],
          "requestBody": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RPCRequest"
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "Successful response",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/RPCResponse"
                  }
                }
              }
            },
            "400": {
              "description": "Bad request"
            },
            "401": {
              "description": "Unauthorized"
            },
            "404": {
              "description": "Method not found"
            },
            "500": {
              "description": "Internal server error"
            }
          }
        }
      },
      "/methods": {
        "get": {
          "summary": "Get available RPC methods",
          "description": "Returns a list of available RPC methods",
          "tags": ["RPC"],
          "responses": {
            "200": {
              "description": "Successful response",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "methods": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "count": {
                        "type": "integer"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }