			"kind": "dev",
			"methods": {
				"cancelProposal(bytes32)": {
					"details": "Allows proposer to cancel proposals that are no longer needed",
					"params": {
						"proposalId": "The proposal to cancel"
					}
				},
				"checkProposalStatus(bytes32)": {
					"params": {
						"proposalId": "The proposal to check"
					},
					"returns": {
						"approvalCount": "Current number of approvals",
						"deadline": "Unix timestamp when proposal expires",
						"executed": "Whether proposal has been executed",
						"expired": "Whether proposal has expired"
					}
				},
				"configureGasSubsidy(bool,uint256,uint256)": {
					"details": "Only deployer can configure subsidy settings",
					"params": {
						"dailyLimit": "Maximum total gas subsidies per day (in wei)",
						"enabled": "Whether contract should sponsor gas costs",
						"maxSubsidy": "Maximum gas cost to subsidize per transaction (in wei)"
					}
				},
				"constructor": {
					"details": "Sets deployer for emergency recovery and initializes rotation timer"
				},
				"depositGasSubsidy()": {
					"details": "Anyone can deposit to sponsor user gas costs (likely protocol or treasury)"
				},
				"emergencyResetOwners(address[])": {
					"details": "Can only be called by deployer if 15+ days have passed since last ownership rotation",
					"params": {
						"_addresses": "New authorized addresses to set"
					}
				},
				"emergencyWithdraw(bytes32,address,address,uint256)": {
					"params": {
						"amount": "Amount to withdraw",
						"proposalId": "Unique identifier for emergency withdrawal",
						"to": "Emergency recipient address",
						"token": "Token to withdraw (address(0) for ETH)"
					}
				},
				"executeMetaTransaction(address,bytes,uint256,address,address,uint256,uint256)": {
					"details": "Contract pays all gas costs from its pool - user pays nothing",
					"params": {
						"amount": "Amount to transfer",
						"nonce": "Nonce for replay protection",
						"signature": "User's signature authorizing the transaction",
						"slippageBps": "Slippage tolerance in basis points",
						"to": "Recipient address",
						"token": "Token address (address(0) for ETH)",
						"user": "Original user who signed the transaction"
					}
				},
				"getBalance(address)": {
					"params": {
						"token": "Token address (address(0) for ETH)"
					},
					"returns": {
						"_0": "Current balance"
					}
				},
				"getRequiredApprovals()": {
					"returns": {
						"_0": "Number of approvals needed for execution"
					}
				},
				"hasApproved(bytes32,address)": {
					"params": {
						"addr": "The address to check",
						"proposalId": "The proposal to check"
					},
					"returns": {
						"_0": "Whether the address has approved the proposal"
					}
				},
				"multisigTransfer(uint256,address,address,uint256,uint256)": {
					"details": "Each authorized address must call this function with the same nonce to approve the transfer.      Proposal ID is generated internally to prevent front-running attacks.      Supports native ETH and any ERC20 token with slippage protection for fee-on-transfer tokens.",
					"params": {
						"amount": "Amount to transfer",
						"nonce": "User-provided nonce for proposal uniqueness (prevents front-running)",
						"slippageBps": "Maximum acceptable slippage in basis points (0-1000, 10000 = 100%)",
						"to": "Recipient address",
						"token": "Token contract address (address(0) for ETH)"
					}
				},
				"pause()": {
					"details": "Only deployer can pause contract in emergency situations"
				},
				"proposeNextOwners(uint256,address[])": {
					"details": "Each current authorized address must call this function with the same nonce to approve the rotation.      Proposal ID is generated internally to prevent front-running attacks.      Current owners CANNOT set themselves as new owners - enforces true rotation.      Automatically handled by external blockchain systems.",
					"params": {
						"newOwners": "Array of new authorized addresses",
						"nonce": "User-provided nonce for proposal uniqueness (prevents front-running)"
					}
				},
				"setAuthorizedAddresses(address[])": {
					"details": "Can only be called once by the deployer for initial setup",
					"params": {
						"_addresses": "Array of addresses to authorize (minimum 3 required)"
					}
				},
				"setTrustedForwarder(address)": {
					"details": "Only deployer can set the trusted forwarder for security",
					"params": {
						"forwarder": "Address of the trusted forwarder contract"
					}
				},
				"unpause()": {
					"details": "Only deployer can unpause contract"
				},
				"withdrawGasSubsidy(uint256)": {
					"details": "Only deployer can withdraw unused subsidy funds",
