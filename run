#!/bin/bash

set -e  # Exit immediately if a command exits with a non-zero status.

PG_PORT=${PG_PORT:-5332}
export PG_PORT

trap ctrl_c INT

HAS_BEEN_INTERRUPTED=false

function ctrl_c() {
    HAS_BEEN_INTERRUPTED=true
    cd postgres_${PG_PORT}
    docker compose down
    cd ..
}

function is_first_run() {
    [ ! -f ".RUN" ]
}

if is_first_run; then
    echo "Installing node dependencies"
    yarn install || { echo "Error: Dependencies failed to install"; exit 1; }
    echo "Ok, dependencies installed"
    
    docker compose version || { echo "Error: Docker and docker compose are not installed: please refer to https://docs.docker.com/compose/install/"; exit 1; }
    echo "Ok, docker compose installed"
    
    if ! command -v bun &> /dev/null; then
        echo "Warning: Bun is not installed. For better performance, consider installing Bun: https://bun.sh/"
    else
        echo "Ok, Bun is installed"
    fi
    
    touch .RUN
fi

CLEAN="false"
PORT=53550

while getopts "p:d:c:i:" opt; do
    case $opt in
        p) PORT=$OPTARG;;
        d) PG_PORT=$OPTARG;;
        c) CLEAN=$OPTARG;;
        i) IDENTITY_FILE=$OPTARG;;
    esac
done
shift $((OPTIND -1))

START_COMMAND=$(command -v bun &> /dev/null && echo "yarn start:bun" || echo "yarn start")

echo "Starting the node with $START_COMMAND"

export IDENTITY_FILE=$IDENTITY_FILE

PG_FOLDER="postgres_${PG_PORT}"
[ ! -d "$PG_FOLDER" ] && cp -r postgres $PG_FOLDER
cd $PG_FOLDER || exit

docker compose down --volumes --remove-orphans --timeout 30 || true
docker rm -f $(docker ps -aq) || true
docker volume prune -f
docker network prune -f

if ! docker compose up -d; then
    echo "Error: Failed to start PostgreSQL container"
    docker compose logs
    exit 1
fi

cd ..

echo -n "Waiting for the database to be available"
COUNT=0
while ! nc -z localhost $PG_PORT; do 
    echo -n "."
    ((COUNT++))
    if [ $COUNT -gt 30 ]; then
        echo "Timeout waiting for the database to be available"
        docker logs ${PG_FOLDER}_db_1
        exit 1
    fi
    sleep 1
done
echo " Database is ready!"

if ! RPC_PORT=$PORT PG_PORT=$PG_PORT IDENTITY_FILE=$IDENTITY_FILE $START_COMMAND; then
    if [ "$HAS_BEEN_INTERRUPTED" == "true" ]; then
        echo "RPC exited successfully"
    else
        echo "Error: RPC failed to start or crashed"
        exit_code=$?
    fi
else
    echo "RPC exited successfully"
    exit_code=0
fi

cd $PG_FOLDER
docker compose down
cd ..

exit $exit_code