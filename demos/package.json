{
    "name": "morph",
    "version": "0.0.1",
    "description": "Morph",
    "author": "Morth Team",
    "license": "none",
    "private": true,
    "main": "src/index.ts",
    "scripts": {
        "build": "rimraf dist && tsc",
        "lint": "eslint . --ext .ts",
        "prettier-format": "prettier --config .prettierrc.json modules/**/*.ts --write",
        "test": "echo \"Error: no test specified\" && exit 1",
        "test:web2": "npx nodemon --exec ts-node -r tsconfig-paths/register src/tests/web2.ts",
        "start": "node --loader ts-node/esm -r tsconfig-paths/register src/index.ts",
        "start:dev": "npx nodemon --exec ts-node -r tsconfig-paths/register src/index.ts"
    },
    "devDependencies": {
        "@types/node": "^18.16.19",
        "@typescript-eslint/eslint-plugin": "^5.44.0",
        "@typescript-eslint/parser": "^5.44.0",
        "eslint": "^8.28.0",
        "eslint-config-prettier": "^8.5.0",
        "eslint-plugin-import": "^2.26.0",
        "eslint-plugin-prettier": "^4.2.1",
        "nodemon": "^3.0.1",
        "prettier": "^2.8.0",
        "rimraf": "^3.0.2",
        "ts-node": "^10.9.1",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^4.9.3"
    },
    "dependencies": {
        "@types/express": "^4.17.17",
        "@types/node-forge": "^1.3.2",
        "axios": "1.4.0",
        "axios-retry": "^3.5.1",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "node-forge": "^1.3.1",
        "pubsub-js": "^1.9.4",
        "socket.io": "^4.7.1",
        "socket.io-client": "^4.7.1",
        "sqlite3": "^5.1.6",
        "terminal-kit": "^3.0.0",
        "typeorm": "^0.3.17"
    }
}
