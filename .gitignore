# ===========================================
# Demos Node - .gitignore
# ===========================================

# ---- Runtime & Data ----
node_modules/
.bun/
dist/
output/
*.db
*.sqlite3
# Ignore everything in `data/` (runtime DBs, chain blobs, l2ps state, ...)
# EXCEPT the committed state-restore snapshot under `data/snapshot/`.
# The negation works because we use `data/*` (not `data/`) — `data/` with
# trailing slash refuses to recurse, so any `!data/...` rule would be
# ignored. The raw `.snapshot-restore/` source dump (213 MB uncompressed)
# is NOT committed — see entry near the bottom.
data/*
!data/snapshot/
docker_data/
postgres_*/
neo4j_data/
ipfs*/
logs/
logs_*/
*.log
nohup.out
last_crash_memory_usage.txt
blocked_ips.json
.RUN

# ---- Environment & Secrets ----
.env
.env.local
.env.*.local
mnemonic.txt
certs/
*.pem
keyfile.json
keyfile_password.txt
twitter_cookies.json
.tlsnotary-key
.demos_id*
wallet.demos
publickey_*
public.key
private.key
demos_peerlist.json
src/ssl/

# ---- Build & Cache ----
bun.lockb
package-lock.json
*.tsbuildinfo
.gitbook-cache.json
architecture/

# ---- OS & Editor ----
.DS_Store
.vscode/
.trunk/
.aider*

# ---- Local artifacts ----
ClaudeDocs/
captraf.sh
history/tmp/

